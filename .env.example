NODE_ENV=development
DATABASE_URL=postgresql://gateway:gateway_local@127.0.0.1:5432/gateway
REDIS_URL=redis://127.0.0.1:6379
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
API_KEY_PEPPER=replace-with-a-separate-random-secret
AUDIT_IP_HASH_SECRET=replace-with-an-independent-random-secret
ADMIN_LOGIN_THROTTLE_SECRET=replace-with-an-independent-random-secret
# Empty means no proxy is trusted. Production must set only the exact CIDRs
# of its real reverse proxies; use loopback only for a local proxy.
TRUST_PROXY_CIDRS=
UPSTREAM_BASE_URL=http://127.0.0.1:4010/v1
UPSTREAM_API_KEY=configure-only-in-local-env
UPSTREAM_DEFAULT_MODEL=test-model
PAYMENT_DRIVER=test
# Privacy: keep real WeChat credentials in local or secret-managed env only.
# Never commit app secrets, login codes, session keys, cookies, or tokens.
# Local development only. Production must set NODE_ENV=production and this to false.
WECHAT_TEST_LOGIN_ENABLED=true
WECHAT_LOGIN_RATE_LIMIT_PER_MINUTE=30
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# WeChat Pay production placeholders. Keep real values in server env or a
# secret manager only; never commit merchant keys, private keys, certificates,
# API v3 keys, payment notifications, cookies, or tokens.
WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=
