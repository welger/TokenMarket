{
  "name": "api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm prisma:generate",
    "build": "nest build && node -e \"require('node:fs').accessSync('dist/main.js')\"",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "pretest": "pnpm prisma:generate",
    "test": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "pretest:e2e": "pnpm prisma:generate",
    "test:e2e": "node --no-warnings --experimental-vm-modules ./node_modules/jest/bin/jest.js --config test/jest-e2e.config.cjs",
    "pretypecheck": "pnpm prisma:generate",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "lint": "pnpm typecheck",
    "preprisma:seed": "pnpm prisma:generate",
    "prisma:seed": "tsc -p tsconfig.seed.json && node .seed-dist/prisma/seed.js",
    "prisma:generate": "prisma generate",
    "prisma": "prisma"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "argon2": "^0.44.0",
    "joi": "^17.13.3",
    "pg": "^8.16.3",
    "redis": "^6.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "dotenv": "^17.2.3",
    "jest": "^30.2.0",
    "prisma": "^7.1.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.5",
    "typescript": "^5.9.3"
  }
}
