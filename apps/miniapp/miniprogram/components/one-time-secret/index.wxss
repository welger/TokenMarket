.secret-mask {
  position: fixed;
  z-index: 20;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(15, 23, 42, 0.62);
}

.secret-card {
  width: 100%;
  padding: 34rpx 30rpx;
  border-radius: 22rpx;
  background: #fff;
}

.secret-title {
  display: block;
  color: #111827;
  font-size: 34rpx;
  font-weight: 800;
}

.secret-desc {
  display: block;
  margin-top: 14rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.5;
}

.secret-value {
  display: block;
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 14rpx;
  background: #111827;
  color: #e5e7eb;
  font-family: monospace;
  font-size: 22rpx;
  line-height: 1.55;
  word-break: break-all;
}

.secret-button,
.secret-secondary {
  margin-top: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.secret-button {
  background: #07c160;
  color: #fff;
}

.secret-secondary {
  background: #f3f4f6;
  color: #111827;
}
