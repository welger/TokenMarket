.usage-card {
  padding: 30rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 18rpx;
  background: #fbfcfd;
}

.usage-alert {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #f4f7f5;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.metric-row {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 24rpx;
}

.metric-row.small {
  grid-template-columns: 1fr 1fr;
}

.metric {
  min-width: 0;
}

.metric.main {
  display: grid;
  grid-template-columns: 64rpx 1fr;
  column-gap: 16rpx;
}

.metric-icon {
  width: 64rpx;
  height: 64rpx;
  grid-row: span 2;
}

.metric-icon.small {
  width: 42rpx;
  height: 42rpx;
  margin-bottom: 8rpx;
}

.metric-label {
  display: block;
  color: #8a8f99;
  font-size: 24rpx;
  line-height: 1.4;
}

.metric-value {
  display: block;
  overflow: hidden;
  color: #151b2d;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.metric-text {
  display: block;
  margin-top: 8rpx;
  color: #202637;
  font-size: 27rpx;
  font-weight: 650;
  line-height: 1.35;
}

.usage-divider {
  height: 1rpx;
  margin: 28rpx 0;
  background: #e5e7eb;
}
