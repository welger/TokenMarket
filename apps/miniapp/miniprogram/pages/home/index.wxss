.page {
  min-height: 100vh;
  padding: 72rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #fff;
  color: #151b2d;
}

.hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.hero-title {
  color: #101827;
  font-size: 54rpx;
  font-weight: 800;
  line-height: 1.18;
}

.hero-subtitle,
.intro,
.section-meta,
.model-name,
.support-subtitle {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 1.5;
}

.status-card {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  margin-top: 32rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 14rpx;
  background: #fff;
}

.status-divider,
.quick-separator,
.support-divider {
  width: 1rpx;
  background: #e5e7eb;
}

.status-divider {
  height: 44rpx;
}

.intro {
  display: block;
  margin-top: 22rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1rpx 1fr 1rpx 1fr;
  align-items: center;
  margin: 48rpx 0 48rpx;
}

.quick-separator {
  height: 156rpx;
}

.quick-item {
  display: flex;
  align-items: center;
  flex-direction: column;
  min-width: 0;
}

.quick-icon {
  width: 98rpx;
  height: 98rpx;
  margin-bottom: 24rpx;
}

.quick-title {
  color: #151b2d;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 1.25;
}

.quick-subtitle {
  margin-top: 10rpx;
  color: #8a8f99;
  font-size: 24rpx;
}

.section {
  padding: 40rpx 0;
  border-top: 1rpx solid #e5e7eb;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.section-title {
  color: #202637;
  font-size: 34rpx;
  font-weight: 750;
}

.link-action,
.center-link {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #6b7280;
  font-size: 26rpx;
}

.link-icon,
.row-icon {
  width: 28rpx;
  height: 28rpx;
  opacity: 0.78;
}

.model-row {
  display: flex;
  align-items: center;
  gap: 22rpx;
  min-width: 0;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0f3;
}

.model-icon {
  width: 76rpx;
  height: 76rpx;
  flex: none;
}

.model-main {
  flex: 1;
  min-width: 0;
}

.model-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.model-title {
  color: #151b2d;
  font-size: 30rpx;
  font-weight: 700;
}

.model-pill {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #dff7e8;
  color: #07a84f;
  font-size: 22rpx;
}

.model-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #8a8f99;
  font-size: 24rpx;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #c5cad3;
}

.status-dot.success {
  background: #07c160;
}

.center-link {
  justify-content: center;
  padding-top: 26rpx;
}

.support-row {
  display: grid;
  grid-template-columns: 1fr 1rpx 1fr;
  gap: 28rpx;
  padding: 28rpx 0 20rpx;
  border-top: 1rpx solid #e5e7eb;
}

.support-item {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.support-icon {
  width: 64rpx;
  height: 64rpx;
  flex: none;
}

.support-title {
  display: block;
  color: #151b2d;
  font-size: 28rpx;
  font-weight: 650;
}

.support-subtitle {
  display: block;
  font-size: 23rpx;
}

.empty,
.section-error,
.page-error {
  color: #8a8f99;
  font-size: 26rpx;
  line-height: 1.5;
}

.section-error,
.page-error {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.text-button,
.reload-button {
  margin: 0;
  padding: 0 18rpx;
  border: 0;
  background: transparent;
  color: #07a84f;
  font-size: 24rpx;
  line-height: 2;
}

.skeleton {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton-title,
.skeleton-line,
.skeleton-card,
.skeleton-grid {
  border-radius: 14rpx;
  background: #f1f3f5;
}

.skeleton-title {
  width: 260rpx;
  height: 62rpx;
}

.skeleton-line {
  width: 360rpx;
  height: 34rpx;
}

.skeleton-card {
  height: 96rpx;
}

.skeleton-grid {
  height: 220rpx;
}

.skeleton-card.tall {
  height: 320rpx;
}
