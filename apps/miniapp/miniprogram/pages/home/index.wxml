<view class="page">
  <view wx:if="{{loading}}" class="skeleton">
    <view class="skeleton-title"></view>
    <view class="skeleton-line wide"></view>
    <view class="skeleton-card"></view>
    <view class="skeleton-grid"></view>
    <view class="skeleton-card tall"></view>
  </view>

  <view wx:else>
    <view class="hero">
      <text class="hero-title">模型网关</text>
      <text class="hero-subtitle">稳定、透明的多模型 API 服务</text>
    </view>

    <view class="status-card">
      <status-row
        title="{{serviceStatusText}}"
        tone="success"
        bind:tap="goServices"
      />
      <view class="status-divider"></view>
      <status-row
        title="{{operatorText}}"
        tone="{{operatorTone}}"
        bind:tap="goProfile"
      />
    </view>

    <text class="intro">多模型 API 网关和开发接口服务</text>

    <view class="quick-grid">
      <view class="quick-item" bindtap="goServices">
        <image class="quick-icon" src="/assets/icons/models.png" mode="aspectFit" />
        <text class="quick-title">查看模型</text>
        <text class="quick-subtitle">浏览可用模型</text>
      </view>
      <view class="quick-separator"></view>
      <view class="quick-item" bindtap="goServices">
        <image class="quick-icon" src="/assets/icons/plans.png" mode="aspectFit" />
        <text class="quick-title">选择套餐</text>
        <text class="quick-subtitle">按需选择套餐</text>
      </view>
      <view class="quick-separator"></view>
      <view class="quick-item" bindtap="goServices">
        <image class="quick-icon" src="/assets/icons/api-docs.png" mode="aspectFit" />
        <text class="quick-title">API 文档</text>
        <text class="quick-subtitle">接入指南与文档</text>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">本月用量</text>
        <text class="section-meta">{{periodText}}</text>
      </view>
      <usage-summary
        usage="{{usage}}"
        hasPlans="{{hasPlans}}"
        emptyText="{{planEmptyText}}"
        errorText="{{usageError}}"
      />
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">模型服务状态</text>
        <view class="link-action" bindtap="goServices">
          <text>全部模型</text>
          <image class="link-icon" src="/assets/icons/right.png" mode="aspectFit" />
        </view>
      </view>
      <view wx:if="{{modelError}}" class="section-error">
        <text>{{modelError}}</text>
        <button class="text-button" bindtap="reload">重新加载</button>
      </view>
      <view wx:elif="{{!hasModels}}" class="empty">{{modelEmptyText}}</view>
      <view wx:else class="model-list">
        <view wx:for="{{models}}" wx:key="name" class="model-row" bindtap="goServices">
          <image class="model-icon" src="{{item.icon}}" mode="aspectFit" />
          <view class="model-main">
            <view class="model-title-row">
              <text class="model-title">{{item.displayName}}</text>
              <text class="model-pill">{{item.statusText}}</text>
            </view>
            <text class="model-name">{{item.name}}</text>
          </view>
          <view class="model-status">
            <text>{{item.statusText}}</text>
            <view class="status-dot {{item.statusTone}}"></view>
          </view>
          <image class="row-icon" src="/assets/icons/right.png" mode="aspectFit" />
        </view>
      </view>
      <view class="center-link" bindtap="goServices">
        <text>查看全部模型状态</text>
        <image class="link-icon" src="/assets/icons/right.png" mode="aspectFit" />
      </view>
    </view>

    <view class="support-row">
      <view class="support-item" bindtap="goProfile">
        <image class="support-icon" src="/assets/icons/support.png" mode="aspectFit" />
        <view>
          <text class="support-title">联系客服</text>
          <text class="support-subtitle">在线支持与帮助</text>
        </view>
      </view>
      <view class="support-divider"></view>
      <view class="support-item" bindtap="goProfile">
        <image class="support-icon" src="/assets/icons/safety.png" mode="aspectFit" />
        <view>
          <text class="support-title">合规与安全</text>
          <text class="support-subtitle">平台规则与隐私政策</text>
        </view>
      </view>
    </view>

    <view wx:if="{{pageError}}" class="page-error">
      <text>{{pageError}}</text>
      <button class="reload-button" bindtap="reload">重新加载</button>
    </view>
  </view>
</view>
