.page {
  min-height: 100vh;
  padding: 64rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.eyebrow {
  display: block;
  color: #07a84f;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.title {
  display: block;
  margin-top: 14rpx;
  color: #101827;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.22;
}

.subtitle {
  display: block;
  margin-top: 18rpx;
  color: #8a8f99;
  font-size: 27rpx;
  line-height: 1.55;
}

.card-list {
  margin-top: 42rpx;
}

.card {
  padding: 30rpx 28rpx;
  border: 1rpx solid #e5e7eb;
  border-radius: 18rpx;
  background: #fbfcfd;
}

.card + .card {
  margin-top: 22rpx;
}

.card-title {
  display: block;
  color: #202637;
  font-size: 31rpx;
  font-weight: 750;
}

.card-desc {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 25rpx;
  line-height: 1.5;
}
