POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password

NODE_ENV=development
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
API_KEY_PEPPER=replace-with-a-separate-random-secret
AUDIT_IP_HASH_SECRET=replace-with-an-independent-random-secret
ADMIN_LOGIN_THROTTLE_SECRET=replace-with-an-independent-random-secret

TRUST_PROXY_CIDRS=127.0.0.1/32
PAYMENT_DRIVER=test

UPSTREAM_BASE_URL=http://127.0.0.1:4010/v1
UPSTREAM_API_KEY=configure-only-if-needed-for-staging
UPSTREAM_DEFAULT_MODEL=test-model

WECHAT_TEST_LOGIN_ENABLED=false
WECHAT_LOGIN_RATE_LIMIT_PER_MINUTE=30
WECHAT_APP_ID=wx5723c60f8a67a5e2
WECHAT_APP_SECRET=replace-with-server-side-wechat-app-secret

WECHAT_PAY_MCH_ID=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/wechat-pay/apiclient_key.pem
WECHAT_PAY_PLATFORM_CERT_PATH=/run/secrets/wechat-pay/platform_cert.pem
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_NOTIFY_URL=https://api-staging.yourtoken.work/payments/wechat/notify
